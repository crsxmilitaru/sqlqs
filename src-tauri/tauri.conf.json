{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "SQL Query Studio",
  "version": "0.1.6",
  "identifier": "com.sqlqs.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SQL Query Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "decorations": false,
        "visible": false,
        "backgroundColor": "#0f172a",
        "transparent": true,
        "windowEffects": {
          "effects": [
            "mica"
          ],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost http://tauri.localhost https://generativelanguage.googleapis.com; font-src 'self' data:",
      "dangerousDisableAssetCspModification": [
        "style-src"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": [
          "sql"
        ],
        "name": "SQL Script",
        "description": "SQL script file",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/crsxmilitaru/sqlqs/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhFRkMzOTc1OEI5RTEyMDEKUldRQkVwNkxkVG44anZUTHhGY3RwNUk3VVFudDFHZzFQY3lRY25oNmI2cWlhR2xQUWhXUEF3ZmEK"
    }
  }
}
